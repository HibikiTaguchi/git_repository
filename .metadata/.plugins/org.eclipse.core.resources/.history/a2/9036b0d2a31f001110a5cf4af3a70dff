package jp.co.sss.practice.p08.repository;

import java.util.List;

import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.data.jpa.repository.Query;

import jp.co.sss.practice.p08.entity.FruitsShopItems;
import jp.co.sss.practice.p08.entity.Type;

public interface FruitsShopItemsRepository extends JpaRepository<FruitsShopItems,Integer> {
	@Query("SELECT f FROM FruitsShopItems f WHERE f.price BETWEEN :min AND :max AND f.type=:type ORDER \n"
			+ "BY f.price,f.itemId")
	List<FruitsShopItems> findQueryByPriceRangeAndType(Integer min, Integer max, Type type);
}	
