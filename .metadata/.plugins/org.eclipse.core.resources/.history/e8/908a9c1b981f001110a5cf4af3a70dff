package jp.co.sss.practice.p08.q03.controller;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Controller;
import org.springframework.ui.Model;
import org.springframework.web.bind.annotation.GetMapping;

import jp.co.sss.practice.p08.entity.Type;
import jp.co.sss.practice.p08.repository.FruitsShopItemsRepository;
import jp.co.sss.practice.p08.repository.TypeRepository;

@Controller
public class Practice0803Controller {
	@Autowired
	FruitsShopItemsRepository fsiRepo;
	@Autowired
	TypeRepository typeRepo;
	
	@GetMapping("/fruits_shop/query/input")
	public String showInput(Model model) {
		model.addAttribute("types", typeRepo.findAll());
		return "practice08/03/search_input";
	}

	@GetMapping("/fruits_shop/query/result")
	public String getResultAndShowIt(Integer minPrice,
			  Integer maxPrice, Integer typeId , Model model) {
		Type type = new Type();
		type.setTypeId(typeId);
		List<FruitsShopItems> fsiList = fsiRepo.findQueryByPriceRangeAndType(minPrice, maxPrice, type);
		model.addAttribute("fsiList", fsiList)
		return "practice08/03/items_list";
	}
}
